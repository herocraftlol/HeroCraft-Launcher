{
  "name": "herocraft-launcher",
  "version": "1.0.0",
  "description": "Launcher officiel HeroCraft",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "fr.herocraft.launcher",
    "productName": "HeroCraft Launcher",
    "copyright": "© 2025 HeroCraft",
    "icon": "src/assets/logo.png",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "src/assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/logo.png",
      "installerHeaderIcon": "src/assets/logo.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HeroCraft Launcher"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/logo.png",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/logo.png",
      "category": "Game"
    },
    "files": ["src/**/*", "node_modules/**/*"],
    "directories": { "output": "dist" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "node-fetch": "^3.3.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0"
  }
}
